# Cloudinary — required for production (Vercel)
# Create a free account at https://cloudinary.com
# Then: Settings → Upload → Add upload preset (unsigned) → copy preset name
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset

# Leave blank for local dev — images will upload to the Go backend's ./uploads/ folder
